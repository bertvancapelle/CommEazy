{
  "name": "commeazy",
  "version": "1.0.0",
  "private": true,
  "description": "Privacy-first family communication — inclusive, multilingual, zero server storage",
  "scripts": {
    "start": "react-native start",
    "ios": "react-native run-ios",
    "android": "react-native run-android",
    "lint": "eslint 'src/**/*.{ts,tsx}' --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:i18n": "node scripts/validate-i18n.js",
    "test:a11y": "jest --testPathPattern=accessibility",
    "test:encryption": "jest --testPathPattern=encryption",
    "compliance:check": "node scripts/check-compliance.js",
    "bundle:analyze": "react-native-bundle-visualizer",
    "clean": "watchman watch-del-all && rm -rf node_modules ios/Pods && npm install && cd ios && pod install",
    "format:locales": "prettier --write 'src/locales/*.json'",
    "format": "prettier --write 'src/**/*.{ts,tsx,json}'",
    "postinstall": "node scripts/patch-packages.js"
  },
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "^3.0.11",
    "@d11/react-native-fast-image": "^8.13.0",
    "@notifee/react-native": "^9.1.8",
    "@nozbe/watermelondb": "^0.25.5",
    "@nozbe/with-observables": "^1.6.0",
    "@op-engineering/op-sqlite": "^9.3.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-camera-roll/camera-roll": "^7.10.2",
    "@react-native-community/blur": "^4.4.1",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/geolocation": "^3.4.0",
    "@react-native-community/slider": "^4.5.2",
    "@react-native-firebase/app": "^21.7.1",
    "@react-native-firebase/auth": "^21.7.1",
    "@react-native-firebase/messaging": "^21.7.1",
    "@react-native-google-signin/google-signin": "^14.0.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "@xmpp/client": "0.14.0",
    "base-64": "^1.0.0",
    "date-fns": "^3.6.0",
    "i18next": "^23.11.0",
    "ical.js": "^2.2.1",
    "libsodium-wrappers": "0.8.2",
    "react": "19.2.3",
    "react-i18next": "^14.1.0",
    "react-native": "0.84.1",
    "react-native-app-auth": "^8.1.0",
    "react-native-callkeep": "^4.3.16",
    "react-native-camera-kit": "^17.0.1",
    "react-native-device-info": "^10.13.1",
    "react-native-fs": "^2.20.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-image-crop-picker": "^0.51.1",
    "react-native-image-picker": "^8.2.1",
    "react-native-incall-manager": "^4.2.1",
    "react-native-keep-awake": "^4.0.0",
    "react-native-keychain": "^8.2.0",
    "react-native-libsodium": "^1.7.0",
    "react-native-localize": "^3.1.0",
    "react-native-maps": "^1.10.3",
    "react-native-permissions": "^4.1.5",
    "react-native-qrcode-svg": "^6.3.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-sherpa-onnx": "^0.2.0",
    "react-native-svg": "15.12.1",
    "react-native-track-player": "^4.1.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-uuid": "^2.0.3",
    "react-native-webrtc": "^124.0.7",
    "react-native-webview": "^13.16.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-proposal-decorators": "^7.24.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/plugin-transform-private-property-in-object": "^7.28.6",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.2",
    "@react-native-community/cli-platform-android": "20.1.2",
    "@react-native-community/cli-platform-ios": "20.1.2",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@testing-library/react-native": "^12.4.0",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/react": "^19.1.1",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.3.0",
    "@typescript-eslint/parser": "^7.3.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "detox": "^20.20.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "react-native-bundle-visualizer": "^3.1.3",
    "react-test-renderer": "^19.2.3",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "react-native",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|libsodium-wrappers|libsodium)/)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 30,
        "functions": 45,
        "lines": 55,
        "statements": 55
      }
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.4"
  }
}
