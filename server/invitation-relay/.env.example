# CommEazy Invitation Relay Configuration
PORT=5283
HOST=127.0.0.1

# Blob TTL in days (auto-cleanup)
BLOB_TTL_DAYS=7

# Maximum blob size in bytes
MAX_BLOB_SIZE=4096

# Cleanup interval in milliseconds (default: 1 hour)
CLEANUP_INTERVAL_MS=3600000

# Database path
DB_PATH=./invitations.db

# Logging
LOG_LEVEL=info
