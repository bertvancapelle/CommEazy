# CommEazy API Gateway Configuration
PORT=8443
HOST=0.0.0.0

# JWT Secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_64_BYTE_HEX

# JWT Token Expiry
JWT_ACCESS_TOKEN_EXPIRY=24h
JWT_REFRESH_TOKEN_EXPIRY=30d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Backend Services (localhost — co-located)
PUSH_GATEWAY_URL=http://127.0.0.1:5282
INVITATION_RELAY_URL=http://127.0.0.1:5283
PROSODY_HTTP_URL=http://127.0.0.1:5280

# Apple App Attest
APPLE_APP_ID=com.commeazy.app
APPLE_TEAM_ID=YOUR_TEAM_ID
# Environment: production or development
APPLE_ATTEST_ENV=development

# Google Play Integrity (Android — future)
# GOOGLE_PACKAGE_NAME=com.commeazy.app
# GOOGLE_PROJECT_NUMBER=123456789

# Redis (optional — attestation store persistence)
# Without Redis, attestation data is stored in-memory (lost on restart)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
